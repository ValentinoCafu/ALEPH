# GenLayer AI Arbitration Backend - Environment Variables

# Private key for wallet (required for writing to blockchain)
# Format: 0x... (hex string)
# IMPORTANT: Keep this file private and never commit it to version control
# To get your private key: MetaMask → Account Details → Export Private Key
PRIVATE_KEY=aqui-va-tu-private-key

# Deployed contract address on GenLayer Studio Online
# This is a public contract address on the GenLayer Bradbury testnet
CONTRACT_ADDRESS=0x5844F58a9E2263d71C1e055765682880864785C3

# Supabase Storage Configuration (for file uploads)
# Create a project at https://supabase.com and create a storage bucket
# Then add your credentials here
SUPABASE_URL=aqui-va-tu-supabase-url
SUPABASE_SERVICE_ROLE_KEY=aqui-va-tu-supabase-key
